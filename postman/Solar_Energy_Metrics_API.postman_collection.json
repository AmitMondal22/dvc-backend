                  "query": [
                    {\n                      \"key\": \"fromDate\",\n                      \"value\": \"2020-01-01\"\n                    },\n                    {\n                      \"key\": \"toDate\",\n                      \"value\": \"2020-01-02\"\n                    }\n                  ]\n                }\n              },\n              \"status\": \"Not Found\",\n              \"code\": 404,\n              \"header\": [],\n              \"body\": \"{\n  \\\"message\\\": \\\"No device data found for the specified period\\\"\n}\"\n            },\n            {\n              \"name\": \"Unauthorized\",\n              \"originalRequest\": {\n                \"method\": \"GET\",\n                \"header\": [],\n                \"url\": {\n                  \"raw\": \"{{base_url}}/api/device/1/solar-metrics\",\n                  \"host\": [\n                    \"{{base_url}}\"\n                  ],\n                  \"path\": [\n                    \"api\",\n                    \"device\",\n                    \"1\",\n                    \"solar-metrics\"\n                  ]\n                }\n              },\n              \"status\": \"Unauthorized\",\n              \"code\": 401,\n              \"header\": [],\n              \"body\": \"{\n  \\\"message\\\": \\\"No token provided\\\"\n}\"\n            }\n          ]
        },
        {
