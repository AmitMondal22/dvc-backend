                    "solar-metrics"
                  ]
                }
              },
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": "{\n  \"message\": \"Device not found\"\n}"
            },
            {
              "name": "No Data Found",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/device/1/solar-metrics?fromDate=2020-01-01&toDate=2020-01-02",
                  "host": [
                    "{{base_url}}"
